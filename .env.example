# Скопіюйте у .env на сервері (не комітьте .env).
# docker compose --env-file .env ... підхоплює змінні для контейнера через env_file у compose.

BOT_TOKEN=123456:ABC-DEF_from_BotFather
ADMIN_ID=123456789

# Публічний HTTPS URL Web App (як у NPM + Cloudflare). Має бути доступний з інтернету для Telegram.
WEB_APP_URL=https://wartovyi.example.com/

# Опційно: перевизначити шлях до SQLite (у Docker зазвичай задає docker-compose)
# BOT_DB_PATH=/data/bot_database_v6.db
